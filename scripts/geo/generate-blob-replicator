    def nullable_int_property(name)
      <<~JSON.chomp
            "#{name}": {
              "type": [
                "integer",
                "null"
              ]
            }
      JSON
    end

    def string_property(name)
      <<~JSON.chomp
            "#{name}": {
              "type": "string"
            }
      JSON
    end

    def status_properties_json
      p = status_field_prefix

      properties = [
        nullable_int_property("#{p}_count"),
        nullable_int_property("#{p}_checksum_total_count"),
        nullable_int_property("#{p}_checksummed_count"),
        nullable_int_property("#{p}_checksum_failed_count"),
