        "#{p}_checksum_total_count",
        "#{p}_checksummed_count",
        "#{p}_checksum_failed_count",
        "#{p}_synced_count",
        "#{p}_failed_count",
        "#{p}_registry_count",
        "#{p}_verification_total_count",
        "#{p}_verified_count",
        "#{p}_verification_failed_count",
        "#{p}_synced_in_percentage",
        "#{p}_verified_in_percentage"
