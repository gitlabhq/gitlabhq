    # -- Geo tracking DB migration --

    def generate_geo_migration
      migration_class = "Create#{replicable_name_camel}Registry"
      file_path = "ee/db/geo/migrate/#{timestamp}_create_#{replicable_name}_registry.rb"

      write_file(file_path, <<~RUBY)
        # frozen_string_literal: true

        class #{migration_class} < Gitlab::Database::Migration[#{MIGRATION_VERSION}]
          milestone '#{milestone}'

          def change
            create_table :#{registry_table_name}, id: :bigserial, force: :cascade, if_not_exists: true do |t|
              t.bigint :#{foreign_key_name}, null: false
              t.datetime_with_timezone :created_at, null: false
              t.datetime_with_timezone :last_synced_at
              t.datetime_with_timezone :retry_at
              t.datetime_with_timezone :verified_at
              t.datetime_with_timezone :verification_started_at
              t.datetime_with_timezone :verification_retry_at
              t.integer :state, default: 0, null: false, limit: 2
              t.integer :verification_state, default: 0, null: false, limit: 2
              t.integer :retry_count, default: 0, limit: 2, null: false
              t.integer :verification_retry_count, default: 0, limit: 2, null: false
              t.boolean :checksum_mismatch, default: false, null: false
              t.binary :verification_checksum
              t.binary :verification_checksum_mismatched
              t.text :verification_failure, limit: 255
              t.text :last_sync_failure, limit: 255

              t.index :#{foreign_key_name}, name: :index_#{registry_table_name}_on_#{foreign_key_name}, unique: true
              t.index :retry_at
              t.index :state
              # To optimize performance of #{registry_class_name}.verification_failed_batch
              t.index :verification_retry_at,
                name: :#{registry_table_name}_failed_verification,
                order: "NULLS FIRST",
                where: "((state = 2) AND (verification_state = 3))"
              # To optimize performance of #{registry_class_name}.needs_verification_count
              t.index :verification_state,
                name: :#{registry_table_name}_needs_verification,
                where: "((state = 2) AND (verification_state = ANY (ARRAY[0, 3])))"
              # To optimize performance of #{registry_class_name}.verification_pending_batch
              t.index :verified_at,
                name: :#{registry_table_name}_pending_verification,
                order: "NULLS FIRST",
                where: "((state = 2) AND (verification_state = 0))"
            end
          end
        end
      RUBY
    end

    # -- Sharding key helpers --

    def sharding_key_reference_table_for(key)
      case key
      when 'project_id'
        'projects'
      when 'namespace_id'
        'namespaces'
      when 'organization_id'
        'organizations'
      end
    end

    # For backward compatibility
    def sharding_key_reference_table
      sharding_key_reference_table_for(sharding_key)
    end

    def sharding_key_column_definitions
      sharding_keys.map { |key| "t.bigint :#{key}" }.join("\n              ")
    end

    def sharding_key_index_definitions
      sharding_keys.map { |key| "t.index :#{key}" }.join("\n              ")
    end

    def sharding_key_foreign_key_definitions
      sharding_keys.map do |key|
        ref_table = sharding_key_reference_table_for(key)
        "add_concurrent_foreign_key :#{state_table_name}, :#{ref_table}, column: :#{key}, on_delete: :cascade"
      end.join("\n            ")
    end

    def sharding_key_not_null_constraint
      # Single key: make it NOT NULL in the column definition instead
      return unless sharding_keys.size > 1

      "add_multi_column_not_null_constraint(:#{state_table_name}, #{sharding_keys.map { |k| ":#{k}" }.join(', ')})"
    end

    def sharding_key_column_definition
      if sharding_keys.size == 1
        "t.bigint :#{sharding_key}, null: false"
      else
        # Multiple keys: columns are nullable, constraint enforces at least one
        sharding_key_column_definitions
      end
    end

    def sharding_key_index_definition
      if sharding_keys.size == 1
        "t.index :#{sharding_key}"
      else
        sharding_key_index_definitions
      end
    end

    def sharding_key_foreign_key_definition
      if sharding_keys.size == 1
        ref_table = sharding_key_reference_table_for(sharding_key)
        "add_concurrent_foreign_key :#{state_table_name}, :#{ref_table}, column: :#{sharding_key}, on_delete: :cascade"
      else
        sharding_key_foreign_key_definitions
      end
    end

    def sharding_key_trigger_install(key)
      <<~RUBY.chomp
        install_sharding_key_assignment_trigger(
          table: :#{state_table_name},
          sharding_key: :#{key},
          parent_table: :#{table_name},
          parent_sharding_key: :#{key},
