    # -------------------------------------------------------------------------
    # Selective sync scope helpers
    # -------------------------------------------------------------------------

    def scope_method
      case sharding_key
      when 'project_id'
        'project_id_in'
      when 'namespace_id'
        'group_id_in'
      when 'organization_id'
        'organization_id_in'
      else
        'organization_id_in'
      end
    end

    def selective_sync_scope_body
      body = case sharding_key
             when 'project_id'
               <<~RUBY
                 replicables = params.fetch(:replicables, all)
                 replicables = replicables.primary_key_in(params[:primary_key_in]) if params[:primary_key_in].present?

                 return replicables unless node.selective_sync?

                 if node.selective_sync_by_namespaces?
                   replicables.project_id_in(node.projects.select(:id))
                 elsif node.selective_sync_by_organizations?
                   organization_ids = node.organizations.pluck_primary_key
                   return none if organization_ids.empty?

                   replicables.where(project_id: ::Project.where(organization_id: organization_ids).select(:id))
                 else
                   raise ::Geo::Errors::UnknownSelectiveSyncType.new(selective_sync_type: node.selective_sync_type)
                 end
               RUBY
             when 'namespace_id'
               <<~RUBY
                 replicables = params.fetch(:replicables, all)
                 replicables = replicables.primary_key_in(params[:primary_key_in]) if params[:primary_key_in].present?

                 return replicables unless node.selective_sync?

                 if node.selective_sync_by_namespaces?
                   replicables.group_id_in(node.namespaces_for_group_owned_replicables.select(:id))
                 elsif node.selective_sync_by_organizations?
                   organization_ids = node.organizations.pluck_primary_key
                   return none if organization_ids.empty?

                   replicables.where(namespace_id: ::Namespace.where(organization_id: organization_ids).select(:id))
                 else
                   raise ::Geo::Errors::UnknownSelectiveSyncType.new(selective_sync_type: node.selective_sync_type)
                 end
               RUBY
             when 'organization_id'
               <<~RUBY
                 replicables = params.fetch(:replicables, all)
                 replicables = replicables.primary_key_in(params[:primary_key_in]) if params[:primary_key_in].present?

                 return replicables unless node.selective_sync?

                 if node.selective_sync_by_namespaces? || node.selective_sync_by_shards?
                   namespace_ids = node.namespaces_for_group_owned_replicables.select(:id)
                   organization_ids = ::Namespace.id_in(namespace_ids).distinct(:organization_id).select(:organization_id)
                   return none if organization_ids.empty?

                   replicables.organization_id_in(organization_ids)
                 elsif node.selective_sync_by_organizations?
                   organization_ids = node.organizations.pluck_primary_key
                   return none if organization_ids.empty?

                   replicables.organization_id_in(organization_ids)
                 else
                   raise ::Geo::Errors::UnknownSelectiveSyncType.new(selective_sync_type: node.selective_sync_type)
                 end
               RUBY
             end

      # Indent relative to the heredoc template. The model template uses
      # <<~RUBY with 8-space base indent. The interpolation point is also at
      # 8 spaces, so we need 8 more spaces of indent (16 total in output:
      # module Geo > class > class << self > def body) minus 8 stripped = 8.
      indent = ' ' * 8
      body.chomp.lines.map { |l| l.strip.empty? ? "\n" : "#{indent}#{l}" }.join
    end

    def scope_definition
      case sharding_key
      when 'project_id'
        "scope :project_id_in, ->(ids) { where(project_id: ids) }"
      when 'namespace_id'
        "scope :group_id_in, ->(ids) { joins(:group).merge(::Namespace.id_in(ids)) }"
      when 'organization_id'
        "scope :organization_id_in, ->(ids) { where(organization_id: ids) }"
      end
    end

    # -------------------------------------------------------------------------
    # Validation
    # -------------------------------------------------------------------------

    def validate!
      errors = []
      errors << '--replicable-name is required' unless replicable_name
      errors << '--model-class is required' unless model_class
      errors << '--table-name is required' unless table_name
      errors << '--sharding-key is required' if sharding_keys.empty?
      errors << '--milestone is required' unless milestone

      valid_keys = %w[project_id namespace_id organization_id]
      invalid_keys = sharding_keys - valid_keys
      unless invalid_keys.empty?
        errors << "--sharding-key must be one of: #{valid_keys.join(', ')} (got invalid: #{invalid_keys.join(', ')})"
      end

      return if errors.empty?

      errors.each { |e| warn "ERROR: #{e}" }
      exit 1
    end

