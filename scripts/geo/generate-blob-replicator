# rubocop:disable Style/PerlBackrefs -- Vibe-coded generator
# rubocop:disable Style/StringConcatenation -- Vibe-coded generator
module Geo
  class BlobReplicatorGenerator
    MIGRATION_VERSION = '2.3'

    attr_reader :replicable_name, :model_class, :table_name, :sharding_keys, :milestone, :dry_run,
      :upload_partition

    def initialize(options)
      @replicable_name = options[:replicable_name]
      @model_class = options[:model_class]
      @table_name = options[:table_name]
      @sharding_keys = parse_sharding_keys(options[:sharding_keys])
      @milestone = options[:milestone]
      @dry_run = options[:dry_run] || false
      @upload_partition = options[:upload_partition] || false
      @files_created = []
      @files_modified = []
    end

    def parse_sharding_keys(keys)
      return [] if keys.nil? || keys.empty?

      keys.flat_map { |k| k.split(',') }.map(&:strip).uniq
    end

    # For backward compatibility and single-key scenarios
    def sharding_key
      sharding_keys.first
    end

    def run
      validate!

      puts "Generating Geo blob replicator for #{replicable_name}..."
      puts "  Model class:       #{model_class}"
      puts "  Table name:        #{table_name}"
      puts "  Sharding key(s):   #{sharding_keys.join(', ')}"
      puts "  Milestone:         #{milestone}"
      puts "  Upload partition:  #{upload_partition}"
      puts

      generate_new_files
      patch_existing_files

      print_summary
    end

