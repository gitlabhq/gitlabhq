    def patch_array_in_file(file_path, anchor:, new_line:, after_anchor: true)
      unless File.exist?(file_path)
        warn "  [SKIP]   #{file_path} (file not found)"
        return
      end

      content = File.read(file_path)

      if content.include?(new_line.strip)
        puts "  [SKIP]   #{file_path} (already contains entry)"
        return
      end

      anchor_index = content.index(anchor)
      unless anchor_index
        warn "  [WARN]   #{file_path} (anchor '#{anchor}' not found, manual edit required)"
        return
      end

      if after_anchor
        # Find the end of the anchor line
        line_end = content.index("\n", anchor_index)
        anchor_line = content[anchor_index..line_end]

        # If the anchor line is the last element (no trailing comma),
        # add a comma to it and remove the trailing comma from the new entry.
        unless anchor_line.rstrip.end_with?(',')
          content.insert(line_end, ',')
          line_end += 1 # account for the inserted comma
          new_line = new_line.sub(/,\s*$/, '')
        end

        content.insert(line_end + 1, "#{new_line}\n")
      else
        # Find the start of the anchor line
        line_start = content.rindex("\n", anchor_index)
        line_start = line_start ? line_start + 1 : 0
        content.insert(line_start, "#{new_line}\n")
      end

      if dry_run
        puts "  [PATCH]  #{file_path}"
        return
      end

      File.write(file_path, content)
      @files_modified << file_path
      puts "  [PATCH]  #{file_path}"
    end

    def insert_before_line(file_path, anchor:, new_content:, before_anchor: false)
      unless File.exist?(file_path)
        warn "  [SKIP]   #{file_path} (file not found)"
        return
      end

      content = File.read(file_path)

      if content.include?("field :#{graphql_field_name}")
        puts "  [SKIP]   #{file_path} (already contains field)"
        return
      end

      anchor_index = content.index(anchor)
      unless anchor_index
        warn "  [WARN]   #{file_path} (anchor '#{anchor}' not found, manual edit required)"
        return
      end

      if before_anchor
        line_start = content.rindex("\n", anchor_index)
        line_start = line_start ? line_start + 1 : 0
        content.insert(line_start, "#{new_content}\n")
      else
        line_end = content.index("\n", anchor_index)
        content.insert(line_end + 1, "#{new_content}\n")
      end

      if dry_run
        puts "  [PATCH]  #{file_path}"
        return
      end

      File.write(file_path, content)
      @files_modified << file_path
      puts "  [PATCH]  #{file_path}"
    end

    def append_before_last_end(file_path, new_content)
      unless File.exist?(file_path)
        warn "  [SKIP]   #{file_path} (file not found)"
        return
      end

      content = File.read(file_path)

      if content.include?("geo_#{replicable_name}_registry")
        puts "  [SKIP]   #{file_path} (already contains entry)"
        return
      end

      # Insert before the final 'end' in the file
      last_end_index = content.rindex('end')
      unless last_end_index
        warn "  [WARN]   #{file_path} (could not find final 'end', manual edit required)"
        return
      end

      # Detect indentation from the 'end' line and apply it to the new content
      line_start = content.rindex("\n", last_end_index)
      end_indent = line_start ? content[(line_start + 1)...last_end_index] : ''
      # The content inside the block is indented one level deeper than 'end'
      inner_indent = end_indent + '  '

      # Preserve relative indentation within the new content by finding the
      # minimum indentation of non-empty lines and offsetting from there.
      non_empty_lines = new_content.lines.reject { |l| l.strip.empty? }
      min_indent = non_empty_lines.map { |l| l[/^ */].length }.min || 0

      indented_content = new_content.lines.map do |line|
        if line.strip.empty?
          "\n"
        else
          extra = line[/^ */].length - min_indent
          "#{inner_indent}#{' ' * extra}#{line.lstrip}"
        end
      end.join

      # Ensure exactly one newline before 'end'
      indented_content = indented_content.chomp + "\n"

      content.insert(last_end_index, indented_content)

      if dry_run
        puts "  [PATCH]  #{file_path}"
        return
      end

      File.write(file_path, content)
      @files_modified << file_path
      puts "  [PATCH]  #{file_path}"
    end

