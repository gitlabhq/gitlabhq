    # -- Main DB state migration --

    def state_foreign_key_options
      if upload_partition
        # For upload partitions, reference the parent uploads table, not the partition.
        # The partition table has a composite PK (id, model_type) which can't be
        # referenced directly. Instead, we reference the parent uploads table which
        # has a unique constraint on id.
        "{ to_table: :uploads, on_delete: :cascade }"
      else
        '{ on_delete: :cascade }'
      end
    end

    def generate_state_migration
      migration_class = "Create#{replicable_name_camel}States"
      file_path = "db/migrate/#{next_timestamp}_create_#{replicable_name}_states.rb"

      # For upload partitions, we can't use foreign_key in create_table because
      # partition tables have composite PKs. Instead, we add the FK separately.
      if upload_partition
        fk_in_create_table = ''
        fk_after_create = "add_concurrent_foreign_key :#{state_table_name}, :uploads, column: :#{foreign_key_name}, on_delete: :cascade"
      else
        fk_in_create_table = ",\n                foreign_key: #{state_foreign_key_options}"
        fk_after_create = ''
      end

      after_create_statements = [
        fk_after_create,
        sharding_key_foreign_key_definition,
        sharding_key_not_null_constraint
      ].compact.reject(&:empty?)

      after_create_block = after_create_statements.map { |s| "    #{s}" }.join("\n")
      after_create_block = "\n\n#{after_create_block}" unless after_create_block.empty?

      write_file(file_path, <<~RUBY)
        # frozen_string_literal: true

        class #{migration_class} < Gitlab::Database::Migration[#{MIGRATION_VERSION}]
          disable_ddl_transaction!

          milestone '#{milestone}'

          VERIFICATION_STATE_INDEX_NAME = "index_#{state_table_name}_on_verification_state"
          PENDING_VERIFICATION_INDEX_NAME = "index_#{state_table_name}_pending_verification"
          FAILED_VERIFICATION_INDEX_NAME = "index_#{state_table_name}_failed_verification"
          NEEDS_VERIFICATION_INDEX_NAME = "index_#{state_table_name}_needs_verification_id"
          VERIFICATION_STARTED_INDEX_NAME = "index_#{state_table_name}_on_verification_started"

          def up
            create_table :#{state_table_name}, if_not_exists: true do |t|
              t.datetime_with_timezone :verification_started_at
              t.datetime_with_timezone :verification_retry_at
              t.datetime_with_timezone :verified_at
              t.references :#{replicable_name},
                null: false,
                index: { unique: true }#{fk_in_create_table}
              #{sharding_key_column_definition}
              t.integer :verification_state, default: 0, limit: 2, null: false
              t.integer :verification_retry_count, default: 0, limit: 2, null: false
              t.binary :verification_checksum, using: 'verification_checksum::bytea'
              t.text :verification_failure, limit: 255

              t.index :verification_state, name: VERIFICATION_STATE_INDEX_NAME
              t.index :verified_at,
                where: "(verification_state = 0)",
                order: { verified_at: 'ASC NULLS FIRST' },
                name: PENDING_VERIFICATION_INDEX_NAME
              t.index :verification_retry_at,
                where: "(verification_state = 3)",
                order: { verification_retry_at: 'ASC NULLS FIRST' },
                name: FAILED_VERIFICATION_INDEX_NAME
              t.index [:#{foreign_key_name}, :verification_started_at],
                where: "(verification_state = 1)",
                name: VERIFICATION_STARTED_INDEX_NAME
              t.index :#{foreign_key_name},
                where: "((verification_state = 0) OR (verification_state = 3))",
                name: NEEDS_VERIFICATION_INDEX_NAME
              #{sharding_key_index_definition}
            end#{after_create_block}
          end

          def down
            drop_table :#{state_table_name}
          end
        end
      RUBY
    end

    def generate_sharding_key_trigger_migration
      timestamps = additional_timestamps(sharding_keys.size)

      sharding_keys.each_with_index do |key, index|
        key_camel = key.split('_').map(&:capitalize).join
        migration_class = "Add#{replicable_name_camel}States#{key_camel}ShardingKeyTrigger"
        file_path = "db/migrate/#{timestamps[index]}_add_#{replicable_name}_states_#{key}_sharding_key_trigger.rb"

        trigger_install = sharding_key_trigger_install(key)
        trigger_removal = sharding_key_trigger_removal(key)

        # Indent trigger content to 4 spaces (method body inside class)
        indented_install = trigger_install.lines.map { |l| "    #{l}" }.join.chomp
        indented_removal = trigger_removal.lines.map { |l| "    #{l}" }.join.chomp

        # Build as plain string to avoid heredoc indentation issues
        migration_content = [
          "# frozen_string_literal: true",
          "",
          "class #{migration_class} < Gitlab::Database::Migration[#{MIGRATION_VERSION}]",
          "  milestone '#{milestone}'",
          "",
          "  def up",
          indented_install,
          "  end",
          "",
          "  def down",
          indented_removal,
          "  end",
          "end",
          ""
        ].join("\n")

        write_file(file_path, migration_content)
      end
    end

