#!/usr/bin/env ruby
# frozen_string_literal: true

# Script to generate all Geo SSF boilerplate files for a new blob replicator.
#
# This automates the steps described in the issue template:
#   .gitlab/issue_templates/Geo Replicate a new blob type.md
#
# Usage:
#   scripts/geo/generate-blob-replicator \
#     --replicable-name=abuse_report_upload \
#     --model-class=AbuseReport \
#     --table-name=abuse_report_uploads \
#     --sharding-key=organization_id \
#     --milestone=18.10 \
#     --upload-partition
#
# Options:
#   --replicable-name     The snake_case replicable name (e.g. abuse_report_upload)
#   --model-class         The Ruby model class name (e.g. AbuseReport)
#   --table-name          The database table name (e.g. abuse_report_uploads)
#   --sharding-key        The sharding key column(s). Can be specified multiple times
#                         or as a comma-separated list. Valid values:
#                         project_id, namespace_id, organization_id
#                         Example: --sharding-key=organization_id
#                         Example: --sharding-key=project_id,namespace_id,organization_id
#   --milestone           The milestone for this feature (e.g. 18.10)
#   --upload-partition    Generate a dedicated model for an upload partition table
#                         that overrides the composite PK (id, model_type) to use
#                         just `id`, avoiding the need for composite PK support
#                         in the Geo SSF. Also generates the model spec.
#   --dry-run             Print file paths without writing (default: false)
#   --help                Show this help message
#
# Related:
#   - Epic: https://gitlab.com/groups/gitlab-org/-/work_items/20933
#   - Issue: https://gitlab.com/gitlab-org/gitlab/-/issues/589925

require 'optparse'
require 'fileutils'
require 'yaml'
require 'date'
require 'json'

# rubocop:disable Graphql/GraphqlNamePosition -- Vibe-coded generator
# rubocop:disable Layout/ExtraSpacing -- Vibe-coded generator
