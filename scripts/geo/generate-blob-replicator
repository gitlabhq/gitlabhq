        return
      end

      # 1. Add to "required" array: insert before "git_fetch_event_count_weekly"
      required_entries = status_required_fields.map { |f| "    \"#{f}\"" }.join(",\n")
      content = content.sub(
        /    "git_fetch_event_count_weekly"/,
        "#{required_entries},\n\"git_fetch_event_count_weekly\""
