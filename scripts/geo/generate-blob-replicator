    # -- Upload partition model --

    def generate_upload_partition_model
      model_file_path = "ee/app/models/geo/#{replicable_name}.rb"

      write_file(model_file_path, <<~RUBY)
        # frozen_string_literal: true

        # Read-only model for the #{table_name} upload partition table.
        #
        # Upload partition tables are populated automatically by PostgreSQL's
        # list partitioning on model_type. The application writes through the
        # Upload model to the uploads parent table, and PostgreSQL routes the
        # row to the correct partition.
        #
        # This model reads from the partition table for Geo replication. It
        # inherits from Upload to get all Upload behavior (retrieve_uploader,
        # model polymorphic association, absolute_path, etc.).
        #
        # The composite primary key (id, model_type) is overridden to just `id`
        # since `id` is globally unique across all partitions (shared sequence).
        # See: https://gitlab.com/gitlab-org/gitlab/-/issues/536647
        module Geo
          class #{replicable_name_camel} < ::Upload
            include ::Geo::ReplicableModel
            include ::Geo::VerifiableModel
            extend ::ActiveSupport::Concern
            extend ::Gitlab::Utils::Override

            self.table_name = '#{table_name}'
            self.primary_key = :id

            delegate(*::Geo::VerificationState::VERIFICATION_METHODS, to: :#{replicable_name}_state)

            with_replicator Geo::#{replicator_class_name}

            has_one :#{replicable_name}_state,
              autosave: false,
              inverse_of: :#{replicable_name},
              class_name: 'Geo::#{state_class_name}',
              foreign_key: :#{foreign_key_name}

            scope :with_verification_state, ->(state) {
              joins(:#{replicable_name}_state)
                .where(#{state_table_name}: { verification_state: verification_state_value(state) })
            }

            #{scope_definition}

            def verification_state_object
              #{replicable_name}_state
            end

            def #{replicable_name}_state
              super || build_#{replicable_name}_state
            end

            class << self
              extend ::Gitlab::Utils::Override

              override :selective_sync_scope
              def selective_sync_scope(node, **params)
        #{selective_sync_scope_body}
              end

              override :verification_state_model_key
              def verification_state_model_key
                :#{foreign_key_name}
              end

              override :verification_state_table_class
              def verification_state_table_class
                Geo::#{state_class_name}
              end
            end
          end
        end
      RUBY
    end

    # Convert CamelCase to snake_case without ActiveSupport
    def to_snake_case(str)
      str.gsub(/::/, '/')
         .gsub(/([A-Z]+)([A-Z][a-z])/, '\1_\2')
         .gsub(/([a-z\d])([A-Z])/, '\1_\2')
         .downcase
    end

    def model_factory_name
      to_snake_case(model_class.split('::').last)
    end

    def generate_upload_partition_model_factory
      write_file("ee/spec/factories/geo/#{replicable_name}.rb", <<~RUBY)
        # frozen_string_literal: true

        FactoryBot.define do
          factory :geo_#{replicable_name}, class: 'Geo::#{replicable_name_camel}' do
            # Upload partition tables are read-only. Data is written through the
            # Upload model to the uploads parent table, and PostgreSQL routes the
            # row to the correct partition by model_type.
            #
            # This factory creates a regular Upload with the appropriate model
            # association, then returns the record from the partition table.
            transient do
              parent_model { create(:#{model_factory_name}) } # rubocop:disable RSpec/FactoryBot/InlineAssociation -- See above
            end

            initialize_with do
              upload = create(:upload, :with_file, model: parent_model)
              Geo::#{replicable_name_camel}.find(upload.id)
            end

            trait :remote_store do
              initialize_with do
                upload = create(:upload, :object_storage, model: parent_model)
                Geo::#{replicable_name_camel}.find(upload.id)
              end
            end

            # Verification state is stored in a separate state table
            # (Geo::#{state_class_name}), not on the model itself.
            trait(:verification_succeeded) do
              after(:create) do |instance|
                state = instance.#{replicable_name}_state
                state.verification_checksum = 'abc'
                state.verification_state = Geo::#{replicable_name_camel}.verification_state_value(:verification_succeeded)
                state.save!
              end
            end

            trait(:verification_failed) do
              after(:create) do |instance|
                state = instance.#{replicable_name}_state
                state.verification_failure = 'Could not calculate the checksum'
                state.verification_state = Geo::#{replicable_name_camel}.verification_state_value(:verification_failed)
                state.save!
              end
            end

            to_create { |instance| instance } # already persisted via initialize_with
          end
        end
      RUBY
    end

