    # -- GraphQL possible_types.json --

    def patch_possible_types_json
      file_path = 'app/assets/javascripts/graphql_shared/possible_types.json'

      unless File.exist?(file_path)
        warn "  [SKIP]   #{file_path} (file not found)"
        return
      end

      content = File.read(file_path)

      if content.include?("\"#{registry_class_name}\"")
        puts "  [SKIP]   #{file_path} (already contains #{registry_class_name})"
        return
      end

      # The Registrable array is alphabetically sorted.
      # Find the correct insertion point.
      registrable_match = content.match(/"Registrable":\s*\[([^\]]+)\]/m)
      unless registrable_match
        warn "  [WARN]   #{file_path} (Registrable array not found, manual edit required)"
        return
      end

      registrable_block = registrable_match[1]
      entries = registrable_block.scan(/"(\w+)"/).flatten

      # Find the correct alphabetical insertion point
      insert_before = entries.find { |e| e > registry_class_name }

      if insert_before
        # Insert before the first entry that comes after alphabetically
        content = content.sub(
          /"#{insert_before}"/,
          "\"#{registry_class_name}\",\n    \"#{insert_before}\""
        )
      else
        # New entry goes at the end; insert after the last entry
        insert_after = entries.last
        content = content.sub(
          /"#{insert_after}"/,
          "\"#{insert_after}\",\n    \"#{registry_class_name}\""
        )
      end

      if dry_run
        puts "  [PATCH]  #{file_path}"
        return
      end

      File.write(file_path, content)
      @files_modified << file_path
      puts "  [PATCH]  #{file_path}"
    end

